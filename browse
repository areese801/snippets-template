#!/usr/bin/env bash
################################################################################
# browse - Interactive snippet browser with fzf
#
# Fuzzy-search and preview snippets interactively. Uses fzf for fuzzy matching
# and bat/cat for live preview.
#
# USAGE:
#   browse                          # Browse all snippets
#   browse --language sql           # Pre-filter to SQL only
#   browse --tag dbt                # Pre-filter by tag (repeatable)
#   browse --print                  # Print code to stdout instead of clipboard
#   browse --query "initial query"  # Start fzf with a pre-filled query
#
# DEPENDENCIES:
#   - fzf (brew install fzf)
#   - bat (optional, for syntax-highlighted preview)
#
# SHELL ALIAS:
#   Add to ~/.zshrc or shell config:
#   alias browse='~/snippets/browse'
################################################################################

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"

# Activate virtual environment if present
if [ -f "${SCRIPT_DIR}/venv/bin/activate" ]; then
    source "${SCRIPT_DIR}/venv/bin/activate"
fi

exec python "${SCRIPT_DIR}/.scripts/browse.py" "$@"
