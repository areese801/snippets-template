#!/usr/bin/env bash
################################################################################
# search - Quick snippet search wrapper
#
# Search snippets by tags, language, or content.
#
# USAGE:
#   search                           # Interactive mode
#   search --tag dbt                 # Filter by tag
#   search --language sql            # Filter by language
#   search --terms "select join"     # Multi-term search
#   search --list-tags               # List all tags
#
# SHELL ALIAS:
#   alias s='~/snippets/search'
################################################################################

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"

# Activate virtual environment if present
if [ -f "${SCRIPT_DIR}/venv/bin/activate" ]; then
    source "${SCRIPT_DIR}/venv/bin/activate"
fi

exec python "${SCRIPT_DIR}/.scripts/search.py" "$@"
